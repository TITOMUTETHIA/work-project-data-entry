@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@using WorkTicketApp.Models
@using WorkTicketApp.Services
@inject IWorkTicketService TicketService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Data Entry</PageTitle>

<h1>Chrome Partners Data Entry</h1>

<div class="row mt-4">
    <div class="col-12">
        <div class="card mb-4">
            <div class="card-header">
                📋 Enter process track sheet
            </div>
            <div class="card-body">
                <p class="card-text">
                    Please fill in the required fields below correctly.
                </p>

                @if (showSuccess)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <strong>Success!</strong> Ticket saved successfully.
                        <button type="button" class="btn-close" @onclick="() => showSuccess = false" aria-label="Close"></button>
                    </div>
                }

                <EditForm Model="@ticket" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="alert alert-danger" />

                    <WorkTicketForm Model="ticket" />

                    <div class="d-flex justify-content-end mt-4">
                        <button type="submit" class="btn btn-primary me-2">💾 Save</button>
                        <button type="button" class="btn btn-secondary" @onclick="ResetForm">🧹 Clear</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    @implements IDisposable

    private WorkTicket ticket = new();
    private bool showSuccess = false;
    private CancellationTokenSource? _cts;
    protected override void OnInitialized()
    {
        ResetForm();
    }

    private async Task HandleValidSubmit()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        ticket.CreatedBy = user.Identity?.Name ?? "Anonymous";
        
        await TicketService.CreateWorkTicketAsync(ticket);
        
        showSuccess = true;
        
        // Reset form for the next entry
        ResetForm();
        
        // Auto-hide success message after a few seconds using a safer, cancellable pattern
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;
        _ = Task.Run(async () =>
        {
            await Task.Delay(3000, token);
            if (!token.IsCancellationRequested)
            {
                await InvokeAsync(() => { showSuccess = false; StateHasChanged(); });
            }
        }, token);
    }

    private void ResetForm()
    {
        ticket = new WorkTicket 
        { 
            StartDateTime = DateTime.Now, 
            EndDateTime = DateTime.Now 
        };
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
