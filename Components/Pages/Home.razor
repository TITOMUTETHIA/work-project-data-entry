@page "/"
@inject IWorkTicketService TicketService

<PageTitle>Home</PageTitle>

<div class="container mt-4">
    <h1 class="mb-4">Dashboard</h1>

    @if (metrics is null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-4">
                <div class="card border-primary mb-3">
                    <div class="card-body text-primary">
                        <h5 class="card-title">Total Tickets</h5>
                        <p class="card-text display-4">@metrics.TotalTickets</p>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card border-success mb-3">
                    <div class="card-body text-success">
                        <h5 class="card-title">Active Tickets</h5>
                        <p class="card-text display-4">@metrics.ActiveTickets</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-info mb-3">
                    <div class="card-body text-info">
                        <h5 class="card-title">New (Last 7 Days)</h5>
                        <p class="card-text display-4">@metrics.TicketsCreatedLast7Days</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DashboardMetricsDto? metrics;

    protected override async Task OnInitializedAsync()
    {
        metrics = await TicketService.GetDashboardMetricsAsync();
    }
}