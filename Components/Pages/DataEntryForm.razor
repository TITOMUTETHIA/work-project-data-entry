@page "/tickets"
@using Microsoft.AspNetCore.Authorization
@using System.Text.Json;
@using WorkTicketApp.Models
@using WorkTicketApp.Services
@using WorkTicketApp.Components.Shared
@using WorkTicketApp.Components
@using Microsoft.AspNetCore.Components.Forms
@inject IWorkTicketService TicketService
@inject ModalService Modal
@inject AuthenticationStateProvider AuthenticationStateProvider
@attribute [Authorize]

<h3 class="text-primary mb-4">📑 Work Ticket Management</h3>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="Search by Ticket #, Operator, or Activity..." 
                   value="@searchTerm" @oninput="OnSearchInput" />
            <button class="btn btn-outline-primary" @onclick="SearchTickets">Search</button>
        </div>
    </div>
    <div class="col-md-6 text-end">
        <a href="/tickets/new" class="btn btn-success"><i class="fas fa-plus"></i> Create New Ticket</a>
    </div>
</div>

@if (tickets == null || tickets.Count == 0)
{
    <div class="alert alert-info">No work tickets have been saved yet.</div>
}
else
{
    <table class="table table-striped table-bordered shadow-sm">
        <thead class="table-dark">
            <tr>
                <th style="cursor: pointer" @onclick='() => SortBy("TicketNumber")'>Ticket # @GetSortIcon("TicketNumber")</th>
                <th style="cursor: pointer" @onclick='() => SortBy("CostCentre")'>Cost Centre @GetSortIcon("CostCentre")</th>
                <th style="cursor: pointer" @onclick='() => SortBy("Activity")'>Activity @GetSortIcon("Activity")</th>
                <th style="cursor: pointer" @onclick='() => SortBy("OperatorName")'>Operator @GetSortIcon("OperatorName")</th>
                <th>Num Operators</th>
                <th>Qty In</th>
                <th>Qty Out</th>
                <th style="cursor: pointer" @onclick='() => SortBy("DT")'>Created Date @GetSortIcon("DT")</th>
                <th style="cursor: pointer" @onclick='() => SortBy("StartDateTime")'>Start Date @GetSortIcon("StartDateTime")</th>
                <th style="cursor: pointer" @onclick='() => SortBy("EndDateTime")'>End Date @GetSortIcon("EndDateTime")</th>
                <th>Material Used</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in tickets)
            {
                <tr>
                    <td>@t.TicketNumber</td>
                    <td>@t.CostCentre</td>
                    <td>@t.Activity</td>
                    <td>@t.OperatorName</td>
                    <td>@t.NumOperators</td>
                    <td>@t.QuantityIn</td>
                    <td>@t.QuantityOut</td>
                    <td>@FormatDate(t.DT)</td>
                    <td>@FormatDate(t.StartDateTime)</td>
                    <td>@FormatDate(t.EndDateTime)</td>
                    <td>@t.MaterialUsed</td>
                    <td>
                        @if (t.TicketNumber is not null)
                        {
                            <a href="@($"/tickets/edit/{t.Id}")" class="btn btn-sm btn-primary">Edit</a>
                            <button class="btn btn-sm btn-danger ms-1" @onclick="() => DeleteTicket(t.Id)">Delete</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <div>
            Showing @((currentPage - 1) * pageSize + 1) to @(Math.Min(currentPage * pageSize, totalCount)) of @totalCount entries
        </div>
        <nav aria-label="Page navigation">
            <ul class="pagination mb-0">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => ChangePage(currentPage - 1)">Previous</button>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page @currentPage of @totalPages</span>
                </li>
                <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => ChangePage(currentPage + 1)">Next</button>
                </li>
            </ul>
        </nav>
    </div>
}

@code {
    @implements IDisposable

    private List<WorkTicket> tickets = new();
    private string searchTerm = "";
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int totalPages => totalCount == 0 ? 1 : (int)Math.Ceiling((double)totalCount / pageSize);
    private string sortBy = "DT";
    private bool sortAscending = false;
    private CancellationTokenSource _searchCts = new();

    protected override async Task OnInitializedAsync()
    {
        await SearchTickets();
    }

    private async Task LoadTickets()
    {
        var result = await TicketService.GetWorkTicketsAsync(currentPage, pageSize, searchTerm, sortBy, sortAscending);
        tickets = result.Items;
        totalCount = result.TotalCount;
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";

        // Cancel any previous search task to debounce
        _searchCts.Cancel();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(500, token); // Wait for 500ms of inactivity
            await SearchTickets(); // Perform the search
        }
        catch (OperationCanceledException)
        {
            // This is expected if the user types again quickly. Ignore it.
        }
    }

    private async Task SearchTickets()
    {
        currentPage = 1;
        await LoadTickets();
    }

    private async Task SortBy(string column)
    {
        if (sortBy == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortBy = column;
            sortAscending = true;
        }
        await LoadTickets();
    }

    private string GetSortIcon(string column)
    {
        if (sortBy != column) return "";
        return sortAscending ? "▲" : "▼";
    }

    private async Task ChangePage(int newPage)
    {
        if (newPage < 1 || newPage > totalPages) return;
        currentPage = newPage;
        await LoadTickets();
    }

    private string? FormatDate(string? isoDate)
    {
        if (string.IsNullOrEmpty(isoDate))
        {
            return null;
        }
        if (DateTime.TryParse(isoDate, null, System.Globalization.DateTimeStyles.RoundtripKind, out var date))
        {
            return date.ToString("MM/dd/yyyy HH:mm");
        }
        return isoDate; // Fallback to original string if parsing fails
    }

    private async Task DeleteTicket(int id)
    {
        var confirmed = await Modal.Show("Confirm Delete", "Are you sure you want to delete this ticket? This action cannot be undone.");
        if (confirmed)
        {
            await TicketService.DeleteTicketAsync(id);
            // If the last item on a page is deleted, move to the previous page.
            if (tickets.Count == 1 && currentPage > 1)
            {
                currentPage--;
            }
            await LoadTickets(); // Reload data for the correct page.
        }
    }

    public void Dispose()
    {
        _searchCts.Cancel();
        _searchCts.Dispose();
    }
}