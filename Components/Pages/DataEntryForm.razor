@page "/tickets"
@using Microsoft.AspNetCore.Authorization
@using WorkTicketApp.Helpers
@using Microsoft.AspNetCore.Components.Authorization
@using WorkTicketApp.Models
@inject IWorkTicketService TicketService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@attribute [Authorize]

<h3 class="text-primary mb-4">📑 Saved Work Tickets</h3>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="Search by Ticket #, Operator, or Activity..." 
                   @bind="searchTerm" @bind:event="oninput" @onkeyup="SearchTickets" />
            <button class="btn btn-outline-primary" @onclick="SearchTickets">Search</button>
        </div>
    </div>
    <div class="col-md-6">
        <div class="d-flex flex-column gap-2">
            <div class="input-group input-group-sm">
                <span class="input-group-text" style="width: 100px;">Created</span>
                <input type="date" class="form-control" @bind="filterStartDate" />
                <span class="input-group-text">To</span>
                <input type="date" class="form-control" @bind="filterEndDate" />
            </div>
            <div class="input-group input-group-sm">
                <span class="input-group-text" style="width: 100px;">Modified</span>
                <input type="date" class="form-control" @bind="filterUpdatedStartDate" />
                <span class="input-group-text">To</span>
                <input type="date" class="form-control" @bind="filterUpdatedEndDate" />
                <button class="btn btn-outline-secondary" @onclick="SearchTickets">Filter</button>
            </div>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (tickets == null || tickets.Count == 0)
{
    <div class="alert alert-info">No work tickets have been saved yet.</div>
}
else
{
    <table class="table table-striped table-bordered shadow-sm">
        <thead class="table-dark">
            <tr>
                <th style="cursor: pointer" @onclick='() => SortBy("TicketNumber")'>Ticket # @GetSortIcon("TicketNumber")</th>
                <th style="cursor: pointer" @onclick='() => SortBy("CostCentre")'>Cost Centre @GetSortIcon("CostCentre")</th>
                <th style="cursor: pointer" @onclick='() => SortBy("Activity")'>Activity @GetSortIcon("Activity")</th>
                <th style="cursor: pointer" @onclick='() => SortBy("OperatorName")'>Operator @GetSortIcon("OperatorName")</th>
                <th style="cursor: pointer" @onclick='() => SortBy("CreatedBy")'>Created By @GetSortIcon("CreatedBy")</th>
                <th>Num Operators</th>
                <th>Start</th>
                <th>End</th>
                <th>Qty In</th>
                <th>Qty Out</th>
                <th>Material Used</th>
                <th style="cursor: pointer" @onclick='() => SortBy("UpdatedAt")'>Last Modified @GetSortIcon("UpdatedAt")</th>
                <th style="cursor: pointer" @onclick='() => SortBy("LastModifiedBy")'>Modified By @GetSortIcon("LastModifiedBy")</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in tickets)
            {
                <tr>
                    <td>@t.TicketNumber</td>
                    <td>@t.CostCentre</td>
                    <td>@t.Activity</td>
                    <td>@t.OperatorName</td>
                    <td>@t.CreatedBy</td>
                    <td>@t.NumOperators</td>
                    <td>@FormatUtils.FormatDateTime(t.StartDateTime)</td>
                    <td>@FormatUtils.FormatDateTime(t.EndDateTime)</td>
                    <td>@t.QuantityIn</td>
                    <td>@t.QuantityOut</td>
                    <td>@t.MaterialUsed</td>
                    <td>@FormatUtils.FormatDateTime(t.UpdatedAt)</td>
                    <td>@t.LastModifiedBy</td>
                    <td>
                        @if (t.TicketNumber is not null)
                        {
                            <button class="btn btn-sm btn-primary" @onclick="() => ShowEditModal(t)">Edit</button>
                            <AuthorizeView Roles="Admin">
                                <button class="btn btn-sm btn-danger ms-1" @onclick="() => ShowDeleteConfirmation(t.Id)">Delete</button>
                            </AuthorizeView>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <div>
            Showing @((currentPage - 1) * pageSize + 1) to @(Math.Min(currentPage * pageSize, totalCount)) of @totalCount entries
        </div>
        <nav aria-label="Page navigation">
            <ul class="pagination mb-0">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => ChangePage(currentPage - 1)">Previous</button>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page @currentPage of @totalPages</span>
                </li>
                <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => ChangePage(currentPage + 1)">Next</button>
                </li>
            </ul>
        </nav>
    </div>
}

@if (showDeleteModal)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this ticket?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showEditModal && ticketToEdit != null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <EditForm Model="@ticketToEdit" OnValidSubmit="HandleQuickEditSubmit">
                    <DataAnnotationsValidator />
                    <div class="modal-header">
                        <h5 class="modal-title">Quick Edit Ticket: @ticketToEdit.TicketNumber</h5>
                        <button type="button" class="btn-close" @onclick="CancelEdit"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3"><label class="form-label">Ticket Number</label><InputText @bind-Value="ticketToEdit.TicketNumber" class="form-control" /></div>
                                <div class="mb-3"><label class="form-label">Cost Centre</label><InputText @bind-Value="ticketToEdit.CostCentre" class="form-control" /></div>
                                <div class="mb-3"><label class="form-label">Operator Name</label><InputText @bind-Value="ticketToEdit.OperatorName" class="form-control" /></div>
                                <div class="mb-3"><label class="form-label">Num Operators</label><InputNumber @bind-Value="ticketToEdit.NumOperators" class="form-control" /></div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3"><label class="form-label">Start Date/Time</label><InputDate Type="InputDateType.DateTimeLocal" @bind-Value="ticketToEdit.StartDateTime" class="form-control" /></div>
                                <div class="mb-3"><label class="form-label">End Date/Time</label><InputDate Type="InputDateType.DateTimeLocal" @bind-Value="ticketToEdit.EndDateTime" class="form-control" /></div>
                                <div class="mb-3"><label class="form-label">Quantity In</label><InputNumber @bind-Value="ticketToEdit.QuantityIn" class="form-control" /></div>
                                <div class="mb-3"><label class="form-label">Quantity Out</label><InputNumber @bind-Value="ticketToEdit.QuantityOut" class="form-control" /></div>
                            </div>
                        </div>
                        <div class="mb-3"><label class="form-label">Activity</label><InputTextArea @bind-Value="ticketToEdit.Activity" class="form-control" /></div>
                        <div class="mb-3"><label class="form-label">Material Used</label><InputTextArea @bind-Value="ticketToEdit.MaterialUsed" class="form-control" /></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<WorkTicket> tickets = new();
    private string searchTerm = "";
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int totalPages => totalCount == 0 ? 1 : (int)Math.Ceiling((double)totalCount / pageSize);
    private string sortBy = "CreatedAt";
    private bool sortAscending = false;
    private DateTime? filterStartDate;
    private DateTime? filterEndDate;
    private DateTime? filterUpdatedStartDate;
    private DateTime? filterUpdatedEndDate;
    private bool showDeleteModal = false;
    private int ticketToDeleteId;
    private bool showEditModal = false;
    private WorkTicket? ticketToEdit;
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        await SearchTickets();
    }

    private async Task LoadTickets()
    {
        isLoading = true;
        var result = await TicketService.GetWorkTicketsAsync(currentPage, pageSize, searchTerm, sortBy, sortAscending, filterStartDate, filterEndDate, filterUpdatedStartDate, filterUpdatedEndDate);
        tickets = result.Items;
        totalCount = result.TotalCount;
        isLoading = false;
    }

    private async Task SearchTickets()
    {
        currentPage = 1;
        await LoadTickets();
    }

    private async Task SortBy(string column)
    {
        if (sortBy == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortBy = column;
            sortAscending = true;
        }
        await LoadTickets();
    }

    private string GetSortIcon(string column)
    {
        if (sortBy != column) return "";
        return sortAscending ? "▲" : "▼";
    }

    private async Task ChangePage(int newPage)
    {
        if (newPage < 1 || newPage > totalPages) return;
        currentPage = newPage;
        await LoadTickets();
    }

    private void ShowDeleteConfirmation(int id)
    {
        ticketToDeleteId = id;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        showDeleteModal = false;
    }

    private async Task ConfirmDelete()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (!user.IsInRole("Admin"))
        {
            return;
        }

        await TicketService.DeleteTicketAsync(ticketToDeleteId);
        showDeleteModal = false;
        await LoadTickets();
        if (tickets.Count == 0 && currentPage > 1)
        {
            currentPage--;
            await LoadTickets();
        }
    }

    private void ShowEditModal(WorkTicket ticket)
    {
        // Create a copy for editing to avoid modifying the list directly
        ticketToEdit = new WorkTicket
        {
            Id = ticket.Id,
            TicketNumber = ticket.TicketNumber,
            CostCentre = ticket.CostCentre,
            Activity = ticket.Activity,
            OperatorName = ticket.OperatorName,
            NumOperators = ticket.NumOperators,
            StartDateTime = ticket.StartDateTime,
            EndDateTime = ticket.EndDateTime,
            QuantityIn = ticket.QuantityIn,
            QuantityOut = ticket.QuantityOut,
            MaterialUsed = ticket.MaterialUsed,
            CreatedAt = ticket.CreatedAt,
            CreatedBy = ticket.CreatedBy
        };
        showEditModal = true;
    }

    private void CancelEdit()
    {
        showEditModal = false;
        ticketToEdit = null;
    }

    private async Task HandleQuickEditSubmit()
    {
        if (ticketToEdit == null) return;

        await TicketService.UpdateTicketAsync(ticketToEdit);
        showEditModal = false;
        ticketToEdit = null;
        await LoadTickets(); // Refresh the list
    }
}