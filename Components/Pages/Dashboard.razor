@page "/dashboard"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using WorkTicketApp.Models
@using WorkTicketApp.Services
@inject IWorkTicketService WorkTicketService

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>

@if (metrics == null)
{
    <p><em>Loading metrics...</em></p>
}
else
{
    <div class="row">
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card text-white bg-primary h-100">
                <div class="card-header"><i class="bi bi-ticket-detailed-fill me-2"></i>Total Tickets</div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <h2 class="card-title display-4">@metrics.TotalTickets</h2>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card text-dark bg-warning h-100">
                <div class="card-header"><i class="bi bi-play-circle-fill me-2"></i>Active Tickets</div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <h2 class="card-title display-4">@metrics.ActiveTickets</h2>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card text-white bg-success h-100">
                <div class="card-header"><i class="bi bi-calendar-plus-fill me-2"></i>Created in Last 7 Days</div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <h2 class="card-title display-4">@metrics.TicketsCreatedLast7Days</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-2">
        <div class="col-lg-6 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    Tickets by Cost Centre (Top 10)
                </div>
                <div class="card-body">
                    @if (!metrics.TicketsByCostCentre.Any())
                    {
                        <p class="text-muted">No data available.</p>
                    }
                    else
                    {
                        var max = metrics.TicketsByCostCentre.Max(c => c.Value);
                        foreach (var item in metrics.TicketsByCostCentre)
                        {
                            var percentage = max > 0 ? (double)item.Value / max * 100 : 0;
                            <div class="mb-2">
                                <div class="d-flex justify-content-between">
                                    <strong>@item.Label</strong>
                                    <span>@item.Value</span>
                                </div>
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar" role="progressbar" style="width: @(percentage)%;" aria-valuenow="@item.Value" aria-valuemin="0" aria-valuemax="@max"></div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    Tickets by Operator (Top 10)
                </div>
                <div class="card-body">
                    @if (!metrics.TicketsByOperator.Any())
                    {
                        <p class="text-muted">No data available.</p>
                    }
                    else
                    {
                        var max = metrics.TicketsByOperator.Max(c => c.Value);
                        foreach (var item in metrics.TicketsByOperator)
                        {
                            var percentage = max > 0 ? (double)item.Value / max * 100 : 0;
                            <div class="mb-2">
                                <div class="d-flex justify-content-between">
                                    <strong>@item.Label</strong>
                                    <span>@item.Value</span>
                                </div>
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar bg-info" role="progressbar" style="width: @(percentage)%;" aria-valuenow="@item.Value" aria-valuemin="0" aria-valuemax="@max"></div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DashboardMetricsDto? metrics;

    protected override async Task OnInitializedAsync()
    {
        metrics = await WorkTicketService.GetDashboardMetricsAsync();
    }
}