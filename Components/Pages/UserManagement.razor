@page "/users"
@using Microsoft.AspNetCore.Authorization
@using WorkTicketApp.Models
@using WorkTicketApp.Services
@using System.Security.Claims
@attribute [Authorize(Roles = "Admin")]
@inject IUserService UserService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>User Management</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>User Management</h1>
    </div>

    <div class="card p-3 mb-4">
        <div class="row">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" class="form-control" placeholder="Search by username..." 
                           @bind="searchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (users.Count == 0)
    {
        <div class="alert alert-info">No users found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Username</th>
                        <th>Role</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in users)
                    {
                        <tr>
                            <td>
                                <span class="fw-bold">@user.Username</span>
                                @if (user.Username == currentUsername)
                                {
                                    <span class="badge bg-secondary ms-2">You</span>
                                }
                            </td>
                            <td>
                                @if (user.Role == "Admin")
                                {
                                    <span class="badge bg-danger">Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">User</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (user.Username != currentUsername)
                                {
                                    @if (user.Role != "Admin")
                                    {
                                        <button class="btn btn-outline-success btn-sm me-2" @onclick='() => ChangeRole(user, "Admin")' title="Promote to Admin">
                                            Promote to Admin
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-warning btn-sm me-2" @onclick='() => ChangeRole(user, "User")' title="Demote to User">
                                            Demote to User
                                        </button>
                                    }
                                    <button class="btn btn-outline-info btn-sm me-2" @onclick="() => OpenResetModal(user)" title="Reset Password">
                                        Reset Pass
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteUser(user)" title="Delete User">
                                        Delete
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Cannot edit self</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => LoadUsers(currentPage - 1)">Previous</button>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">Page @currentPage of @totalPages</span>
                    </li>
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => LoadUsers(currentPage + 1)">Next</button>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

@if (showResetModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Reset Password for @selectedUserForReset?.Username</h5>
                    <button type="button" class="btn-close" @onclick="CloseResetModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">New Password</label>
                        <input type="text" class="form-control" @bind="newPassword" placeholder="Enter new password" />
                        <small class="text-muted">Enter the new password for the user.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseResetModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmResetPassword">Reset Password</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<UserDto> users = new();
    private string searchTerm = "";
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int totalPages => (int)Math.Ceiling((double)totalCount / pageSize);
    private bool isLoading = true;
    private string? currentUsername;
    private bool showResetModal = false;
    private UserDto? selectedUserForReset;
    private string newPassword = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUsername = authState.User.Identity?.Name;
        await LoadUsers(1);
    }

    private async Task HandleSearch()
    {
        await LoadUsers(1);
    }

    private async Task LoadUsers(int page)
    {
        if (page < 1) page = 1;
        currentPage = page;
        isLoading = true;
        
        var result = await UserService.GetUsersAsync(currentPage, pageSize, searchTerm);
        users = result.Items;
        totalCount = result.TotalCount;
        
        isLoading = false;
    }

    private async Task ChangeRole(UserDto user, string newRole)
    {
        var success = await UserService.UpdateUserRoleAsync(user.Username, newRole);
        if (success)
        {
            await LoadUsers(currentPage);
        }
    }

    private async Task DeleteUser(UserDto user)
    {
        var success = await UserService.DeleteUserAsync(user.Username);
        if (success)
        {
            await LoadUsers(currentPage);
        }
    }

    private void OpenResetModal(UserDto user)
    {
        selectedUserForReset = user;
        newPassword = "";
        showResetModal = true;
    }

    private void CloseResetModal()
    {
        showResetModal = false;
        selectedUserForReset = null;
        newPassword = "";
    }

    private async Task ConfirmResetPassword()
    {
        if (selectedUserForReset != null && !string.IsNullOrWhiteSpace(newPassword))
        {
            await UserService.ResetPasswordAsync(selectedUserForReset.Username, newPassword);
            CloseResetModal();
        }
    }
}